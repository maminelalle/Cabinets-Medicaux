# ============================================================
# CABINETS MÉDICAUX - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS commiter le fichier .env
# ============================================================

# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────
# Base de données (Supabase PostgreSQL)
# En dev local : postgres://postgres:postgres@localhost:5432/cabinets_medicaux
# ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cabinets_medicaux
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/cabinets_medicaux

# ─────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_service_role_key

# ─────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_this_to_another_very_long_random_secret
REFRESH_TOKEN_EXPIRES_IN=7d

# ─────────────────────────────────────────
# Redis (dev local : redis://localhost:6379)
# Production : Upstash Redis
# ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://your-redis-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ─────────────────────────────────────────
# Email (réinitialisation de mot de passe)
# ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@cabinets-medicaux.com
SMTP_PASS=your_smtp_password
EMAIL_FROM="Cabinets Médicaux <noreply@cabinets-medicaux.com>"

# ─────────────────────────────────────────
# Frontend Vite (préfixe VITE_ obligatoire)
# ─────────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key
